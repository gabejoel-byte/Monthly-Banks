# Copy this file to .streamlit/secrets.toml for local testing (that file is
# gitignored -- never commit a real secret). On Streamlit Community Cloud,
# set this instead via your app's Settings -> Secrets in the dashboard.
#
# When app_password is unset (the default locally), the app has no login
# screen at all -- it only gates access when a password is actually configured,
# which you'd only do on a public deployment.

app_password = "choose-a-password-here"
